{
  "_comment": [
    "Упорядоченные правила ребрендинга Claude -> GigaCode. Применяются СВЕРХУ ВНИЗ:",
    "специфичные (url, cli, dotpath, product) идут раньше общего brand_generic,",
    "чтобы общий 'claude'->'gigacode' не испортил ссылки/команды.",
    "МОДЕЛИ НЕ МАПЯТСЯ: скиллы не выбирают модель (нет поля model: в SKILL.md);",
    "модель задаёт рантайм GigaCode. Флаг --model в skill-creator по умолчанию",
    "берёт модель текущей сессии. Поэтому раздела model_id здесь нет специально.",
    "Каждое правило: pattern (regex), replacement, [flags: 'i'=ignorecase], [case_preserve]."
  ],
  "rules": [
    { "category": "url", "pattern": "claude\\.ai/code", "replacement": "gigacode.ru" },
    { "category": "url", "pattern": "claude\\.com/claude-code", "replacement": "gigacode.ru" },
    { "category": "url", "pattern": "claude\\.ai", "replacement": "gigacode.ru" },
    { "category": "url", "pattern": "claude\\.com", "replacement": "gigacode.ru" },

    { "category": "cli", "pattern": "claude\\s+-p", "replacement": "gigacode -p" },

    { "category": "product", "pattern": "Claude\\s+Code", "replacement": "GigaCode" },
    { "category": "product", "pattern": "Anthropic", "replacement": "GigaCode" },

    { "category": "dotpath", "pattern": "\\.claude", "replacement": ".gigacode" },

    { "category": "brand_generic", "pattern": "claude", "flags": "i", "replacement": "gigacode", "case_preserve": true }
  ]
}
