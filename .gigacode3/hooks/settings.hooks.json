{
  "_comment": "Эталон блока hooks для gigacode3 control-plane под PDLC v3.5. Влить в settings.json конфиг-дома рантайма (~/.gigacode/ прод, ~/.qwen/ локальный тест — заменив пути). Порядок в массивах значим; блокирующие на PreToolUse идут sequential. Логгер последним. disableAllHooks не трогать.",
  "hooks": {
    "PreToolUse": [
      {"matcher": "^Bash$", "sequential": true, "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/destructive-blocker.py", "name": "destructive-blocker"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/evidence-enforcer.py", "name": "evidence-enforcer"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/gate-guard.py", "name": "gate-guard"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]},
      {"matcher": "(Write|Edit|WriteFile|NotebookEdit)", "sequential": true, "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/pii-boundary.py", "name": "pii-boundary"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/tdd-guard.py", "name": "tdd-guard"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/gate-guard.py", "name": "gate-guard"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]},
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "PostToolUse": [
      {"matcher": "(Read|ReadFile|Fetch|WebFetch|Bash)", "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/prompt-guard.py", "name": "prompt-guard"}
      ]},
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "PostToolUseFailure": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "UserPromptSubmit": [
      {"hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/prompt-guard.py", "name": "prompt-guard"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "SubagentStart": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/context-injector.py", "name": "context-injector"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "SubagentStop": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/state-recorder.py", "name": "state-recorder"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "SessionStart": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "Stop": [
      {"sequential": true, "hooks": [
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/phase-gate.py", "name": "phase-gate"},
        {"type": "command", "command": "python3 $HOME/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ]
  }
}
