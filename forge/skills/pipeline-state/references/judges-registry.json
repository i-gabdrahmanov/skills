{
  "$schema": "pipeline-state/judges-registry@1",
  "_comment": "ЕДИНЫЙ источник истины для required_judges и метаданных судей. Читается init.py и patch_manifest_judges.py (через judges_registry.py), чтобы маска не дублировалась. Имена судей ДОЛЖНЫ совпадать с вердиктами run_judge.py (<phase>-judge.json) и фазами PHASE_MAP.",
  "step_masks": {
    "00-brd": ["brd-judge"],
    "02-design": ["design-judge"],
    "02-eval-plan": ["eval-judge"],
    "04-test-*": ["red-judge"],
    "04-build-*": ["build-judge", "reuse-judge"],
    "05-tests": ["coverage-judge"],
    "06-spec": ["spec-judge"],
    "07-deliver-*": ["delivery-judge"]
  },
  "judges": {
    "brd-judge":      {"phase": "brd",      "kind": "hybrid",        "contract": "subagent-prompts.md §7.6"},
    "design-judge":   {"phase": "design",   "kind": "deterministic", "contract": "check_taskplan.py + check_sdd.py"},
    "eval-judge":     {"phase": "eval",     "kind": "hybrid",        "contract": "subagent-prompts.md §7.1"},
    "red-judge":      {"phase": "red",      "kind": "pass-through",  "contract": "subagent-prompts.md §7.2"},
    "build-judge":    {"phase": "build",    "kind": "hybrid",        "contract": "subagent-prompts.md §7.3"},
    "reuse-judge":    {"phase": "reuse",    "kind": "hybrid",        "contract": "subagent-prompts.md §7.7"},
    "coverage-judge": {"phase": "coverage", "kind": "deterministic", "contract": "check_coverage.py"},
    "spec-judge":     {"phase": "spec",     "kind": "deterministic", "contract": "subagent-prompts.md §7.4"},
    "delivery-judge": {"phase": "delivery", "kind": "hybrid",        "contract": "subagent-prompts.md §7.5"}
  }
}
