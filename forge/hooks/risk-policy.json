{
  "_comment": "Policy-as-code для risk-adaptive permission ladder R0–R5 (AI DISRUPT PDLC v3.5). Читается risk_ladder.py / gate-guard.py. deny-first: рисковое по умолчанию запрещено, пока не выполнено requirement уровня. Все regex — Python re, case-insensitive по команде.",
  "version": 1,
  "default_level": "R1",
  "autonomy_auto_max": "R1",
  "_autonomy_note": "Действия с уровнем <= autonomy_auto_max проходят авто (с логом). Выше — нужен requirement. pipeline.json autonomy может переопределить.",

  "destructive_blacklist": [
    "rm\\s+(-[a-z]*\\s+)*-?[rf]*r[rf]*\\s+(-[a-z]*\\s+)*(/|~|\\*|\\$HOME|\\.)(\\s|$)",
    "\\bgit\\s+push\\b.*--force(-with-lease)?\\b.*\\b(main|master|origin)\\b",
    "\\bgit\\s+push\\s+--force\\b(?!.*--force-with-lease)",
    "\\b(DROP|TRUNCATE)\\s+(TABLE|DATABASE|SCHEMA)\\b",
    "\\bchmod\\s+-R?\\s*777\\b",
    "\\bmkfs\\b|\\bdd\\s+if=.*of=/dev/",
    ":\\(\\)\\s*\\{.*\\};:",
    "curl\\s+[^|]*\\|\\s*(sudo\\s+)?(ba)?sh",
    "wget\\s+[^|]*\\|\\s*(sudo\\s+)?(ba)?sh",
    "\\bgit\\s+reset\\s+--hard\\b.*origin"
  ],

  "pii_patterns": [
    "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}",
    "\\b(?:\\d[ -]?){13,16}\\b",
    "\\b\\+?\\d{1,3}[ -]?\\(?\\d{2,4}\\)?[ -]?\\d{3}[ -]?\\d{2}[ -]?\\d{2}\\b",
    "(?i)(api[_-]?key|secret|password|token|bearer)\\s*[=:]\\s*\\S{8,}"
  ],

  "injection_markers": [
    "(?i)ignore (all )?(previous|prior|above) instructions",
    "(?i)disregard (the )?(system|previous) prompt",
    "(?i)you are now (a|an|in) (developer|dan|jailbreak)",
    "(?i)<\\s*important\\s*>.*(exfiltrate|send|leak)",
    "(?i)reveal (your )?(system prompt|instructions)"
  ],

  "path_risk": {
    "_comment": "blast-radius по пути-цели действия. Первое совпадение по порядку выигрывает.",
    "R5": ["(?i).*(risk[-_]?model|scoring[-_]?model|regulat).*"],
    "R4": [
      "(?i).*(application|bootstrap)(-prod|-production)?\\.(ya?ml|properties)$",
      "(?i).*/(prod|production)/.*",
      "(?i).*/(iam|rbac|auth-?z|access-?control)/.*",
      "(?i).*(/db/)?(migration|changelog|liquibase|flyway).*\\.(sql|xml|ya?ml)$"
    ],
    "R3": [
      "(?i).*/(security|auth|authentication|payment|billing|pii|kyc)/.*",
      "(?i).*(secret|credential|keystore|truststore).*"
    ],
    "R2": ["(?i).*/src/main/.*\\.(java|kt)$"],
    "R1": ["(?i).*/src/test/.*", "(?i).*(test|spec).*\\.(java|kt|py)$"],
    "R0": ["(?i).*\\.(md|txt|adoc|rst)$", "(?i).*/docs?/.*"]
  },

  "command_risk": {
    "_comment": "Риск по shell-команде (если путь не дал класс выше).",
    "R2": ["\\bgit\\s+commit\\b"],
    "R3": ["\\bacli\\b.*\\bcreate\\b", "\\bjira\\b.*\\bcreate\\b", "rest/api/\\d+/issue\\b"],
    "R4": ["\\bgit\\s+push\\b", "\\bpull[-_ ]?request\\b", "\\bpullrequests\\b", "\\bacli\\b.*\\bpr\\b"]
  },

  "level_requirements": {
    "_comment": "Что должно быть выполнено, чтобы действие уровня прошло. step = completed-шаг manifest; approval = файл ground/approvals/<key>.json; evidence = ground/evidence/* >= порога.",
    "R0": {"mode": "auto"},
    "R1": {"mode": "auto_log"},
    "R2": {"mode": "require", "steps": ["02-design"], "commit_needs": ["05-tests"], "push_needs": ["05-tests", "06-spec"], "evidence": true},
    "R3": {"mode": "require", "steps": ["02-design"], "approval": "security-review", "evidence": true},
    "R4": {"mode": "require", "approval": "human-approval", "separation_of_duties": true, "evidence": true},
    "R5": {"mode": "require", "approval": "change-advisory", "evidence": true, "audit": true}
  },

  "agent_caps": {
    "_comment": "Separation of duties по agent_type (regex)→max-risk. Активно через sod-enforcer.py (PreToolUse хук), который определяет роль эвристически по prompt/tool_input. Если роль определена — применяется max-risk; если нет — проходим без ограничений. agent_caps НЕ используется напрямую risk_ladder'ом (все субагенты — general-purpose), sod-enforcer читает ROLE_POLICY из своего кода.",
    "(?i)test|coverage|verify": "R1",
    "(?i)spec|uml|document": "R1",
    "(?i)explore|grounder|analyst": "R1",
    "(?i)tech.?design": "R2",
    "(?i)java.?spring|dev|developer|build": "R2",
    "(?i)jira": "R3"
  }
}
