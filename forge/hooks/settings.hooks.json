{
  "_comment": "Эталон блока hooks для gigacode3 control-plane под PDLC v3.5. Пути используют ${PROJECT_ROOT} — resolve_hook_paths.py подставляет реальный путь. Порядок в массивах значим; блокирующие на PreToolUse идут sequential. Логгер последним. disableAllHooks не трогать.",
  "hooks": {
    "PreToolUse": [
      {"matcher": "^(run_shell_command|Bash)$", "sequential": true, "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/destructive-blocker.py", "name": "destructive-blocker"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/fork-syntax-guard.py", "name": "fork-syntax-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/pii-boundary.py", "name": "pii-boundary"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/state-write-guard.py", "name": "state-write-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/evidence-enforcer.py", "name": "evidence-enforcer"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/sod-enforcer.py", "name": "sod-enforcer"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/inline-phase-guard.py", "name": "inline-phase-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/gate-guard.py", "name": "gate-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]},
      {"matcher": "^(write_file|edit|notebook_edit|Write|Edit|WriteFile|NotebookEdit)$", "sequential": true, "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/pii-boundary.py", "name": "pii-boundary"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/state-write-guard.py", "name": "state-write-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/tdd-guard.py", "name": "tdd-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/eval-guard.py", "name": "eval-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/sod-enforcer.py", "name": "sod-enforcer"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/inline-phase-guard.py", "name": "inline-phase-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/gate-guard.py", "name": "gate-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]},
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "PostToolUse": [
      {"matcher": "^(read_file|web_fetch|run_shell_command|Read|ReadFile|Fetch|WebFetch|Bash)$", "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/prompt-guard.py", "name": "prompt-guard"}
      ]},
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "PostToolUseFailure": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "UserPromptSubmit": [
      {"hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/prompt-guard.py", "name": "prompt-guard"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "SubagentStart": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/context-injector.py", "name": "context-injector"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "SubagentStop": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/state-recorder.py", "name": "state-recorder"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "SessionStart": [
      {"matcher": "*", "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ],
    "Stop": [
      {"sequential": true, "hooks": [
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/cost-breaker.py", "name": "cost-breaker"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/phase-gate.py", "name": "phase-gate"},
        {"type": "command", "command": "python3 ${PROJECT_ROOT}/.gigacode/hooks/log-agent.py", "name": "agent-logger"}
      ]}
    ]
  }
}
